NODE_ENV=development
PORT=3000
DATABASE_URL="postgresql://user:password@localhost:5433/relay_db"
JWT_PRIVATE_KEY_BASE64=REPLACE_WITH_BASE64_RSA_PRIVATE_KEY
JWT_PUBLIC_KEY_BASE64=REPLACE_WITH_BASE64_RSA_PUBLIC_KEY
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_COOKIE_NAME=relay_refresh_token
SESSION_COOKIE_NAME=relay_sid
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_PATH=/
# AUTH_COOKIE_DOMAIN=
AUTH_MAX_ACTIVE_SESSIONS_PER_USER=0
AUTH_SESSION_TOUCH_INTERVAL_SECONDS=300
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
EMAIL_VERIFICATION_TOKEN_EXPIRES_IN=20m
EMAIL_VERIFICATION_URL_BASE=http://localhost:3000/verify-email
UPLOAD_LOCAL_ROOT=uploads
UPLOAD_ENABLE_SCAN=false
MESSAGE_EDIT_WINDOW_MINUTES=30
BACKEND_PUBLIC_URL=http://localhost:3000
