// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PlatformRole {
  superadmin
  user
}

enum OrganizationRole {
  owner
  admin
  member
  guest
}

model User {
  id            String                   @id @default(uuid()) @db.Uuid
  email         String                   @unique @db.Citext
  passwordHash  String                   @map("password_hash")
  fullName      String                   @map("full_name") @db.VarChar(255)
  displayName   String?                  @map("display_name") @db.VarChar(80)
  avatarUrl     String?                  @map("avatar_url")
  status        String?                  @db.VarChar(100)
  isActive      Boolean                  @default(true) @map("is_active")
  platformRole  PlatformRole             @default(user) @map("platform_role")
  emailVerifiedAt DateTime?              @map("email_verified_at") @db.Timestamptz(6)
  lastLoginAt   DateTime?                @map("last_login_at") @db.Timestamptz(6)
  createdAt     DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)

  sessions                Session[]
  emailVerificationTokens EmailVerificationToken[]
  organizationsCreated    Organization[]      @relation("organization_created_by")
  organizationMemberships OrganizationMember[] @relation("organization_member_user")
  organizationInvitesSent OrganizationInvite[] @relation("organization_invited_by")
  organizationMembershipInvites OrganizationMember[] @relation("organization_member_invited_by")
  auditActorLogs           AuditLog[]                @relation("audit_actor_user")

  @@map("users")
}

model Session {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  tokenHash    String    @unique @map("token_hash")
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz(6)
  deviceInfo   String?   @map("device_info")
  ipAddress    String?   @map("ip_address") @db.Inet
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastActiveAt DateTime  @default(now()) @map("last_active_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([lastActiveAt])
  @@map("sessions")
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model Organization {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(120)
  slug        String   @unique @db.VarChar(80)
  description String?  @db.VarChar(500)
  avatarUrl   String?  @map("avatar_url")
  isActive    Boolean  @default(true) @map("is_active")
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdById String   @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy User                 @relation("organization_created_by", fields: [createdById], references: [id], onDelete: Restrict)
  members   OrganizationMember[]
  invites   OrganizationInvite[]
  auditLogs AuditLog[]

  @@index([createdById])
  @@index([isActive])
  @@index([deletedAt])
  @@map("organizations")
}

model AuditLog {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String?   @map("organization_id") @db.Uuid
  actorUserId    String?   @map("actor_user_id") @db.Uuid
  action         String    @db.VarChar(120)
  entityType     String    @map("entity_type") @db.VarChar(80)
  entityId       String    @map("entity_id") @db.Uuid
  metadata       Json?     @db.JsonB
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actorUser    User?         @relation("audit_actor_user", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([action, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model OrganizationMember {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  role           OrganizationRole @default(member)
  joinedAt       DateTime         @default(now()) @map("joined_at") @db.Timestamptz(6)
  invitedById    String?          @map("invited_by_id") @db.Uuid
  isActive       Boolean          @default(true) @map("is_active")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation("organization_member_user", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy    User?        @relation("organization_member_invited_by", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId, role])
  @@index([isActive])
  @@map("organization_members")
}

model OrganizationInvite {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  email          String           @db.Citext
  role           OrganizationRole @default(member)
  tokenHash      String           @unique @map("token_hash")
  invitedById    String           @map("invited_by_id") @db.Uuid
  expiresAt      DateTime         @map("expires_at") @db.Timestamptz(6)
  acceptedAt     DateTime?        @map("accepted_at") @db.Timestamptz(6)
  revokedAt      DateTime?        @map("revoked_at") @db.Timestamptz(6)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("organization_invited_by", fields: [invitedById], references: [id], onDelete: Restrict)

  @@index([organizationId, email])
  @@index([organizationId])
  @@index([email])
  @@index([expiresAt])
  @@map("organization_invites")
}
